{
  "name": "properlang",
  "scopeName": "source.properlang",
  "fileTypes": [
    ".pl"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "name": "keyword.control.properlang",
      "match": "(?i)\\b(and|as|const|declare|else|false|fn|for|from|global|if|import|in|instanceof|is|isnt|let|n|new|or|return|this|true|type|types|unless|where|while|xor)\\b|\\B(!in|!instanceof|!is)\\b"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.properlang",
          "begin": "//",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.properlang"
            }
          },
          "end": "\n",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.comment.properlang"
            }
          }
        },
        {
          "name": "comment.block.properlang",
          "begin": "/\\*",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.properlang"
            }
          },
          "end": "\\*/",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.comment.properlang"
            }
          }
        }
      ]
    }
  }
}
