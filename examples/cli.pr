import { Command } from 'commander';
import * as fs from 'fs/promises';

const program = new Command();

program
  .command('bump')
  .option('-s, --silent')
  .option('--amount <value>', 'Amount to bump by', 1)
  .action(({ amount, silent }) => {
    let doc = JSON.parse(fs.readFile('data/counter.json').await);
    doc.value += amount;
    fs.writeFile('data/counter.json').await;
    unless silent:
      console.log(`Bumped by ${amount} to ${doc.value}`);
  });
program.parse();
